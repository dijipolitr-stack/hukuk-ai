   <tr style='mso-yfti-irow:1;height:24.0pt'>
    <td width=586 colspan=3 style='width:439.45pt;padding:0cm 5.4pt 0cm 5.4pt;
    height:24.0pt'>
    <p align=center style='text-align:center'><b style='mso-bidi-font-weight:
    normal'><span style='font-size:9.0pt;font-family:Arial;color:navy'>TEBLİĞ<o:p></o:p></span></b></p>
    </td>
   </tr>
   <tr style='mso-yfti-irow:2;mso-yfti-lastrow:yes;height:24.0pt'>
    <td width=586 colspan=3 style='width:439.45pt;padding:0cm 5.4pt 0cm 5.4pt;
    height:24.0pt'>
    <p class=Balk11pt style='line-height:12.0pt;mso-line-height-rule:exactly'><span
    style='font-size:9.0pt'>Ticaret Bakanlığından:<o:p></o:p></span></p>
    <p class=OrtaBalkBold style='margin-top:2.8pt;line-height:12.0pt;
    mso-line-height-rule:exactly'><span style='font-size:9.0pt'>TARIM VE ORMAN
    BAKANLIĞININ KONTROLÜNE TABİ ÜRÜNLERİN İTHALAT <o:p></o:p></span></p>
    <p class=OrtaBalkBold style='line-height:12.0pt;mso-line-height-rule:exactly'><span
    style='font-size:9.0pt'>DENETİMİ TEBLİĞİ (ÜRÜN GÜVENLİĞİ VE DENETİMİ:
    2026/5)’NDE <o:p></o:p></span></p>
    <p class=OrtaBalkBold style='line-height:12.0pt;mso-line-height-rule:exactly'><span
    style='font-size:9.0pt'>DEĞİŞİKLİK YAPILMASINA DAİR TEBLİĞ <span
    class=GramE>(</span>ÜRÜN GÜVENLİĞİ VE <o:p></o:p></span></p>
    <p class=OrtaBalkBold style='margin-bottom:8.5pt;line-height:12.0pt;
    mso-line-height-rule:exactly'><span style='font-size:9.0pt'>DENETİMİ:
    2026/34<span class=GramE>)</span><o:p></o:p></span></p>
    <p class=Metin style='line-height:12.0pt;mso-line-height-rule:exactly'><b
    style='mso-bidi-font-weight:normal'><span style='font-size:9.0pt'>MADDE 1-</span></b><span
    style='font-size:9.0pt'> <span class=GramE>31/12/2025</span> tarihli ve
    33124 dördüncü mükerrer sayılı Resmî Gazete’de yayımlanan Tarım ve Orman
    Bakanlığının Kontrolüne Tabi Ürünlerin İthalat Denetimi Tebliği (Ürün
    Güvenliği ve Denetimi: 2026/5)’<span class=SpellE>nin</span> Ek-1/<span
    class=SpellE>B’sindeki</span> tabloda yer alan “2922.49” GTİP numaralı
    satır aşağıdaki şekilde değiştirilmiştir.<o:p></o:p></span></p>
    <p class=MsoNormal style='text-align:justify;line-height:12.0pt;mso-line-height-rule:
    exactly'><span style='font-size:9.0pt'>“<o:p></o:p></span></p>
    <div align=center>
    <table class=MsoNormalTable border=1 cellspacing=0 cellpadding=0 width=548
     style='width:411.1pt;border-collapse:collapse;border:none;mso-border-alt:
     solid windowtext .5pt;mso-yfti-tbllook:160;mso-padding-alt:0cm 5.4pt 0cm 5.4pt;
     mso-border-insideh:.5pt solid windowtext;mso-border-insidev:.5pt solid windowtext'>
     <tr style='mso-yfti-irow:0;mso-yfti-firstrow:yes;mso-yfti-lastrow:yes'>
      <td width=66 valign=top style='width:49.8pt;border:solid windowtext 1.0pt;
      mso-border-alt:solid windowtext .5pt;padding:0cm 5.4pt 0cm 5.4pt'>
      <p class=MsoNormal style='text-align:justify;line-height:12.0pt;
      mso-line-height-rule:exactly'><span style='font-size:9.0pt'>2922.49<o:p></o:p></span></p>
      </td>
      <td width=538 valign=top style='width:403.3pt;border:solid windowtext 1.0pt;
      border-left:none;mso-border-left-alt:solid windowtext .5pt;mso-border-alt:
      solid windowtext .5pt;padding:0cm 5.4pt 0cm 5.4pt'>
      <p class=MsoNormal style='text-align:justify;line-height:12.0pt;
      mso-line-height-rule:exactly'><span style='font-size:9.0pt'>Diğerleri
      (2922.49.85.90.35 “<span class=SpellE>Pregabalin</span>” hariç)<o:p></o:p></span></p>
      </td>
     </tr>
    </table>
    </div>
    <p class=MsoNormal align=right style='text-align:right;text-indent:1.0cm;
    line-height:12.0pt;mso-line-height-rule:exactly'><span style='font-size:
    9.0pt'>”<o:p></o:p></span></p>
    <p class=Metin style='line-height:12.0pt;mso-line-height-rule:exactly'><b
    style='mso-bidi-font-weight:normal'><span style='font-size:9.0pt'>MADDE 2- </span></b><span
    style='font-size:9.0pt'>Aynı Tebliğin Ek-2’sindeki tabloda yer alan “<span
    class=GramE>2922.49</span>” GTİP numaralı satır aşağıdaki şekilde değiştirilmiştir.<o:p></o:p></span></p>
    <p class=MsoNormal style='text-align:justify;line-height:12.0pt;mso-line-height-rule:
    exactly;tab-stops:28.3pt 42.55pt'><span style='font-size:9.0pt'>“<o:p></o:p></span></p>
    <div align=center>
    <table class=MsoNormalTable border=1 cellspacing=0 cellpadding=0 width=548
     style='width:411.1pt;border-collapse:collapse;border:none;mso-border-alt:
     solid windowtext .5pt;mso-yfti-tbllook:160;mso-padding-alt:0cm 5.4pt 0cm 5.4pt;
     mso-border-insideh:.5pt solid windowtext;mso-border-insidev:.5pt solid windowtext'>
     <tr style='mso-yfti-irow:0;mso-yfti-firstrow:yes;mso-yfti-lastrow:yes'>
      <td width=66 valign=top style='width:49.8pt;border:solid windowtext 1.0pt;
      mso-border-alt:solid windowtext .5pt;padding:0cm 5.4pt 0cm 5.4pt'>
      <p class=MsoNormal style='text-align:justify;line-height:12.0pt;
      mso-line-height-rule:exactly'><span style='font-size:9.0pt'>2922.49<o:p></o:p></span></p>
      </td>
      <td width=538 valign=top style='width:403.3pt;border:solid windowtext 1.0pt;
      border-left:none;mso-border-left-alt:solid windowtext .5pt;mso-border-alt:
      solid windowtext .5pt;padding:0cm 5.4pt 0cm 5.4pt'>
      <p class=MsoNormal style='text-align:justify;line-height:12.0pt;
      mso-line-height-rule:exactly'><span style='font-size:9.0pt'>Diğerleri
      (veteriner kontrolüne tabi olanlar hariç ve 2922.49.85.90.35 “<span
      class=SpellE>Pregabalin</span>” hariç)<o:p></o:p></span></p>
      </td>
     </tr>
    </table>
    </div>
    <p class=Metin align=right style='text-align:right;text-indent:0cm;
    line-height:12.0pt;mso-line-height-rule:exactly'><span style='font-size:
    9.0pt'>”<o:p></o:p></span></p>
    <p class=Metin style='line-height:12.0pt;mso-line-height-rule:exactly'><b
    style='mso-bidi-font-weight:normal'><span style='font-size:9.0pt'>MADDE 3- </span></b><span
    style='font-size:9.0pt'>Aynı Tebliğin Ek-3’ündeki tabloda yer alan “0713.90.00.00.13”
    GTİP numaralı satırdan sonra gelmek üzere aşağıdaki satırlar eklenmiştir.<o:p></o:p></span></p>
    <p class=MsoNormal style='text-align:justify;text-indent:-3.45pt;
    line-height:12.0pt;mso-line-height-rule:exactly'><span style='font-size:
    9.0pt'>“<o:p></o:p></span></p>
    <div align=center>
    <table class=MsoNormalTable border=1 cellspacing=0 cellpadding=0 width=548
     style='width:411.1pt;border-collapse:collapse;border:none;mso-border-alt:
     solid windowtext .5pt;mso-yfti-tbllook:160;mso-padding-alt:0cm 5.4pt 0cm 5.4pt;
     mso-border-insideh:.5pt solid windowtext;mso-border-insidev:.5pt solid windowtext'>
     <tr style='mso-yfti-irow:0;mso-yfti-firstrow:yes'>
      <td width=64 valign=top style='width:47.7pt;border:solid windowtext 1.0pt;
      mso-border-alt:solid windowtext .5pt;padding:0cm 5.4pt 0cm 5.4pt'>
      <p class=MsoNormal style='text-align:justify;line-height:12.0pt;
      mso-line-height-rule:exactly'><span style='font-size:9.0pt'>09.09<o:p></o:p></span></p>
      </td>
      <td width=495 valign=top style='width:371.1pt;border:solid windowtext 1.0pt;
      border-left:none;mso-border-left-alt:solid windowtext .5pt;mso-border-alt:
      solid windowtext .5pt;padding:0cm 5.4pt 0cm 5.4pt'>
      <p class=MsoNormal style='text-align:justify;line-height:12.0pt;
      mso-line-height-rule:exactly'><span style='font-size:9.0pt'>Anason, Çin
      anasonu, rezene, kişniş, kimyon veya karaman kimyonu tohumları; ardıç
      meyveleri (yalnız tohumluk olanlar)<o:p></o:p></span></p>
      </td>
     </tr>
     <tr style='mso-yfti-irow:1;mso-yfti-lastrow:yes'>
      <td width=64 valign=top style='width:47.7pt;border:solid windowtext 1.0pt;
      border-top:none;mso-border-top-alt:solid windowtext .5pt;mso-border-alt:
      solid windowtext .5pt;padding:0cm 5.4pt 0cm 5.4pt'>
      <p class=MsoNormal style='text-align:justify;line-height:12.0pt;
      mso-line-height-rule:exactly'><span style='font-size:9.0pt'>09.10<o:p></o:p></span></p>
      </td>
      <td width=495 valign=top style='width:371.1pt;border-top:none;border-left:
      none;border-bottom:solid windowtext 1.0pt;border-right:solid windowtext 1.0pt;
      mso-border-top-alt:solid windowtext .5pt;mso-border-left-alt:solid windowtext .5pt;
      mso-border-alt:solid windowtext .5pt;padding:0cm 5.4pt 0cm 5.4pt'>
      <p class=MsoNormal style='text-align:justify;line-height:12.0pt;
      mso-line-height-rule:exactly'><span style='font-size:9.0pt'>Zencefil, safran,
      zerdeçal (<span class=SpellE>curcuma</span>), kekik, <span class=GramE>defne
      yaprakları</span>, <span class=SpellE>köri</span> ve diğer baharat
      (yalnız tohumluk olanlar)<o:p></o:p></span></p>
      </td>
     </tr>
    </table>
    </div>
    <p class=Metin align=right style='text-align:right;line-height:12.0pt;
    mso-line-height-rule:exactly'><span style='font-size:9.0pt'>”<o:p></o:p></span></p>
    <p class=Metin style='line-height:12.0pt;mso-line-height-rule:exactly'><b
    style='mso-bidi-font-weight:normal'><span style='font-size:9.0pt'>MADDE 4- </span></b><span
    style='font-size:9.0pt'>Aynı Tebliğin Ek-7’sindeki tabloda yer alan
    “0901.11.00.00.00” GTİP numaralı satırdan sonra gelmek üzere aşağıdaki
    satırlar eklenmiştir.<o:p></o:p></span></p>
    <p class=MsoNormal style='text-align:justify;line-height:12.0pt;mso-line-height-rule:
    exactly'><span style='font-size:9.0pt'>“<o:p></o:p></span></p>
    <div align=center>
    <table class=MsoNormalTable border=1 cellspacing=0 cellpadding=0 width=548
     style='width:411.1pt;border-collapse:collapse;border:none;mso-border-alt:
     solid windowtext .5pt;mso-yfti-tbllook:160;mso-padding-alt:0cm 5.4pt 0cm 5.4pt;
     mso-border-insideh:.5pt solid windowtext;mso-border-insidev:.5pt solid windowtext'>
     <tr style='mso-yfti-irow:0;mso-yfti-firstrow:yes'>
      <td width=64 valign=top style='width:47.7pt;border:solid windowtext 1.0pt;
      mso-border-alt:solid windowtext .5pt;padding:0cm 5.4pt 0cm 5.4pt'>
      <p class=MsoNormal style='text-align:justify;line-height:12.0pt;
      mso-line-height-rule:exactly'><span style='font-size:9.0pt'>09.09<o:p></o:p></span></p>
      </td>
      <td width=495 valign=top style='width:371.1pt;border:solid windowtext 1.0pt;
      border-left:none;mso-border-left-alt:solid windowtext .5pt;mso-border-alt:
      solid windowtext .5pt;padding:0cm 5.4pt 0cm 5.4pt'>
      <p class=MsoNormal style='text-align:justify;line-height:12.0pt;
      mso-line-height-rule:exactly'><span style='font-size:9.0pt'>Anason, Çin
      anasonu, rezene, kişniş, kimyon veya karaman kimyonu tohumları; ardıç
      meyveleri (ezilmiş veya öğütülmüş olanlar hariç)<o:p></o:p></span></p>
      </td>
     </tr>
     <tr style='mso-yfti-irow:1;mso-yfti-lastrow:yes'>
      <td width=64 valign=top style='width:47.7pt;border:solid windowtext 1.0pt;
      border-top:none;mso-border-top-alt:solid windowtext .5pt;mso-border-alt:
      solid windowtext .5pt;padding:0cm 5.4pt 0cm 5.4pt'>
      <p class=MsoNormal style='text-align:justify;line-height:12.0pt;
      mso-line-height-rule:exactly'><span style='font-size:9.0pt'>09.10<o:p></o:p></span></p>
      </td>
      <td width=495 valign=top style='width:371.1pt;border-top:none;border-left:
