# Veritabanı (DigitalOcean Managed PostgreSQL bağlantı stringi)
DATABASE_URL=postgresql://user:password@host:25060/defaultdb?sslmode=require

# OpenAI (embedding için)
OPENAI_API_KEY=sk-...

# Anthropic (dilekçe motoru için — bir sonraki modülde kullanılacak)
ANTHROPIC_API_KEY=sk-ant-...

# PDF depolama klasörü
PDF_DIR=./pdfs

# Log seviyesi
LOG_LEVEL=INFO
